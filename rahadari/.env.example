# PRIMARY APIs (All have free tiers)
VITE_OPENWEATHER_API_KEY=get_from_openweathermap_org
VITE_OPENROUTE_API_KEY=get_from_openrouteservice_org
VITE_WEATHERAPI_KEY=get_from_weatherapi_com
VITE_TOMORROW_IO_KEY=get_from_tomorrow_io
VITE_GRAPHHOPPER_KEY=get_from_graphhopper_com

# BACKUP APIs (Completely free)
VITE_OPEN_METEO_URL=https://api.open-meteo.com/v1
VITE_NOMINATIM_URL=https://nominatim.openstreetmap.org

# App Configuration
VITE_APP_NAME=Rahadari
VITE_DEFAULT_LANG=en
VITE_CACHE_DURATION=1800000